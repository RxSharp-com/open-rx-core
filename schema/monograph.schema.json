{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-rx-core.example/schema/monograph.schema.json",
  "title": "Monograph",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "drug_id",
    "generic_name",
    "brand_names",
    "rxcui",
    "routes",
    "drug_class",
    "domain_tags",
    "publication_status",
    "review_status",
    "review_level",
    "clinically_usable",
    "PLACEHOLDER_CLINICAL_CONTENT",
    "known_gaps",
    "evidence_source_ids",
    "require_citations_for_clinical_claims",
    "files",
    "reviewers",
    "conflicts_of_interest"
  ],
  "properties": {
    "drug_id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$",
      "minLength": 1
    },
    "generic_name": {
      "type": "string",
      "minLength": 1
    },
    "brand_names": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rxcui": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "RxNorm RxCUI placeholders; may be empty in scaffold."
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "drug_class": {
      "type": "string"
    },
    "domain_tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "publication_status": {
      "type": "string",
      "enum": [
        "draft",
        "published",
        "retired"
      ]
    },
    "review_status": {
      "type": "string",
      "enum": [
        "not_started",
        "source_imported",
        "ai_drafted",
        "needs_clinical_review",
        "needs_revision",
        "approved",
        "published",
        "retired"
      ]
    },
    "review_level": {
      "type": "string",
      "enum": [
        "level_0_admin",
        "level_1_factual",
        "level_2_clinical_wording",
        "level_3_recommendation_impacting",
        "level_4_specialty_high_risk"
      ]
    },
    "last_reviewed": {
      "type": ["string", "null"],
      "format": "date"
    },
    "next_review_due": {
      "type": ["string", "null"],
      "format": "date"
    },
    "clinically_usable": {
      "type": "boolean",
      "const": false,
      "description": "Must remain false until maintainers explicitly change scaffold policy."
    },
    "PLACEHOLDER_CLINICAL_CONTENT": {
      "type": "boolean",
      "description": "Must be false before publication."
    },
    "known_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_source_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "require_citations_for_clinical_claims": {
      "type": "boolean"
    },
    "sections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/monographSection"
      }
    },
    "files": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "patient",
        "clinician",
        "evidence",
        "changelog"
      ],
      "properties": {
        "patient": {
          "type": "string",
          "minLength": 1
        },
        "clinician": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "string",
          "minLength": 1
        },
        "changelog": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "reviewers": {
      "type": "array",
      "items": {
        "$ref": "reviewer.schema.json"
      }
    },
    "conflicts_of_interest": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "changelog_version": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "monographSection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "section_id",
        "title"
      ],
      "properties": {
        "section_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "clinical_recommendation": {
          "type": "boolean",
          "default": false
        },
        "citation_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "content_status": {
          "type": "string",
          "enum": [
            "placeholder",
            "draft",
            "reviewed"
          ]
        }
      },
      "if": {
        "properties": {
          "clinical_recommendation": {
            "const": true
          }
        },
        "required": ["clinical_recommendation"]
      },
      "then": {
        "required": ["citation_ids"],
        "properties": {
          "citation_ids": {
            "type": "array",
            "minItems": 1
          }
        }
      }
    }
  }
}
