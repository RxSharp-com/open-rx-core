{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-rx-core.example/schema/dailymed-section-pointer.schema.json",
  "title": "DailyMedSectionPointerFile",
  "description": "Metadata-only section locators for a specific DailyMed SPL. Does not authorize extraction, evidence packets, summaries, or patient/clinician-facing content.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "drug_id", "source_scope", "pointers"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "drug_id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$",
      "minLength": 1
    },
    "source_scope": {
      "type": "string",
      "enum": [
        "fictional_example",
        "selected_spl",
        "route_group_source",
        "formulation_group_source",
        "temporary_working_source",
        "multi_spl_source"
      ]
    },
    "pointers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sectionPointerRecord"
      }
    }
  },
  "$defs": {
    "sectionPointerRecord": {
      "type": "object",
      "additionalProperties": false,
      "description": "Locator metadata only. Forbidden text-bearing property names are rejected by additionalProperties and by fixture validation guards.",
      "required": [
        "pointer_id",
        "drug_id",
        "source_id",
        "setid",
        "spl_version",
        "labeler",
        "product_title",
        "section_title",
        "section_type",
        "extraction_status",
        "reuse_status",
        "contains_text",
        "text_storage_policy",
        "review_required",
        "source_scope",
        "canonical_status",
        "section_pointer_status"
      ],
      "properties": {
        "pointer_id": {
          "type": "string",
          "minLength": 1
        },
        "drug_id": {
          "type": "string",
          "pattern": "^[a-z0-9_-]+$",
          "minLength": 1
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "setid": {
          "type": "string",
          "minLength": 1
        },
        "spl_version": {
          "type": "string",
          "minLength": 1
        },
        "labeler": {
          "type": "string",
          "minLength": 1
        },
        "product_title": {
          "type": "string",
          "minLength": 1
        },
        "section_title": {
          "type": "string",
          "minLength": 1
        },
        "section_code": {
          "type": "string",
          "minLength": 1
        },
        "section_code_system": {
          "type": "string",
          "minLength": 1
        },
        "section_path": {
          "type": "string",
          "minLength": 1
        },
        "section_identifier": {
          "type": "string",
          "minLength": 1
        },
        "section_url": {
          "type": "string",
          "minLength": 1
        },
        "section_anchor": {
          "type": "string",
          "minLength": 1
        },
        "section_type": {
          "type": "string",
          "enum": [
            "example_section",
            "labeling_section_pointer",
            "contraindications",
            "warnings_and_precautions",
            "adverse_reactions",
            "dosage_and_administration",
            "clinical_pharmacology",
            "microbiology",
            "how_supplied_storage_handling",
            "patient_counseling_information",
            "other"
          ]
        },
        "extraction_status": {
          "type": "string",
          "enum": [
            "pointer_only",
            "extraction_not_started",
            "extraction_blocked",
            "extraction_design_only"
          ]
        },
        "reuse_status": {
          "type": "string",
          "const": "unknown_requires_review"
        },
        "license_note": {
          "type": "string"
        },
        "contains_text": {
          "type": "boolean",
          "const": false
        },
        "text_storage_policy": {
          "type": "string",
          "enum": ["pointer_metadata_only", "no_text_storage_allowed"]
        },
        "last_verified": {
          "type": "string",
          "format": "date"
        },
        "review_required": {
          "type": "boolean",
          "const": true
        },
        "reviewer_notes": {
          "type": "string"
        },
        "route_group": {
          "type": "string",
          "enum": [
            "unknown",
            "not_applicable",
            "oral",
            "injectable",
            "example_route"
          ]
        },
        "formulation_group": {
          "type": "string",
          "enum": [
            "unknown",
            "not_applicable",
            "capsule",
            "powder_for_solution",
            "injection_solution",
            "lyophilized_powder_for_solution",
            "example_formulation"
          ]
        },
        "source_scope": {
          "type": "string",
          "enum": [
            "fictional_example",
            "selected_spl",
            "route_group_source",
            "formulation_group_source",
            "temporary_working_source",
            "multi_spl_source"
          ]
        },
        "canonical_status": {
          "type": "string",
          "const": "non_canonical"
        },
        "section_pointer_status": {
          "type": "string",
          "enum": ["draft", "needs_review", "blocked", "retired"]
        }
      }
    }
  }
}
