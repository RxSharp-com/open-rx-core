{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EvidenceExtractionOutput",
  "allOf": [
    {
      "$ref": "../../schema/agent-output.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "agent_id": {
          "const": "evidence-extraction"
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "output_type",
              "summary",
              "payload"
            ],
            "properties": {
              "output_type": {
                "const": "evidence_packet_draft"
              },
              "summary": {
                "type": "string"
              },
              "citation_ids": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "clinical_recommendation": {
                "type": "boolean"
              },
              "confidence": {
                "type": "string",
                "enum": [
                  "high",
                  "moderate",
                  "low",
                  "uncertain",
                  "needs_human_review"
                ]
              },
              "payload": {
                "type": "object",
                "required": [
                  "proposed_packet"
                ],
                "properties": {
                  "proposed_packet": {
                    "type": "object",
                    "required": [
                      "packet_type",
                      "claim_summary",
                      "source_ids",
                      "requires_human_review",
                      "review_level",
                      "recommendation_impact"
                    ],
                    "properties": {
                      "packet_type": {
                        "type": "string"
                      },
                      "claim_summary": {
                        "type": "string"
                      },
                      "clinical_claim": {
                        "type": ["string", "null"]
                      },
                      "citation_ids": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "source_ids": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "minItems": 1
                      },
                      "requires_human_review": {
                        "type": "boolean",
                        "const": true
                      },
                      "review_level": {
                        "type": "string"
                      },
                      "recommendation_impact": {
                        "type": "string"
                      },
                      "uncertainty_flags": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "proposed_citations": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
