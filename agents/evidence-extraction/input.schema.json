{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EvidenceExtractionInput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "drug_id",
    "source_id",
    "source_type",
    "source_reference"
  ],
  "properties": {
    "drug_id": {
      "type": "string",
      "minLength": 1
    },
    "source_id": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string",
      "enum": [
        "dailymed_label",
        "openfda_label",
        "rxnorm",
        "pubmed_metadata",
        "pmc_open_access",
        "clinicaltrials",
        "fda_safety_communication",
        "cdc_guidance",
        "nih_guidance",
        "open_guideline",
        "human_synthesis",
        "other_public_source"
      ]
    },
    "source_reference": {
      "type": "string",
      "minLength": 1,
      "description": "Public URL, identifier, or repository path for the source."
    },
    "accessed_date": {
      "type": "string",
      "format": "date"
    },
    "extraction_scope": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Optional section scopes, e.g. identity, warnings, pharmacology."
    }
  }
}
